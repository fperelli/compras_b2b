# ==========================================
# Compas B2B - Multi-Tenant Negotiation SaaS
# Environment Variables Configuration
# ==========================================

# -----------------
# Frontend Configuration
# -----------------
# The internal Docker DNS path to reach FastAPI from Next.js container (usually http://agent:8000/api/v1)
BACKEND_API_URL=http://localhost:8000/api/v1
# If deploying Next.js separately, map it to the external URL.

# -----------------
# Backend / Agent Configuration
# -----------------
# LLM Provider options: 'ollama' (Gemini has been disabled)
LLM_PROVIDER=ollama

# Ollama Model - Default is kimi-k2.6
OLLAMA_MODEL=kimi-k2.6

# Ollama Base URL (Local container via Docker compose is http://ollama:11434)
OLLAMA_BASE_URL=http://localhost:11434

# -----------------
# Database Configuration
# -----------------
# Default connects to the containerized Mongo instance
MONGODB_URI=mongodb://localhost:27017/b2b_saas

# -----------------
# Secret / Auth (Future Implementation)
# -----------------
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET="generate_a_random_string_here"
